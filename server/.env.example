# ============================================================================
# Mem0 Enhanced Server Configuration
# ============================================================================

# ============================================================================
# LLM Configuration
# ============================================================================

# OpenAI API Key (required for fact extraction and embedding)
OPENAI_API_KEY=

# Optional: Custom OpenAI-compatible endpoint
# OPENAI_BASE_URL=http://your-llm-host:8080/v1

# Model settings
OPENAI_MODEL=gpt-4.1-nano-2025-04-14
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Embedding dimensions (must match your embedding model)# For bge-m3: 1024# For text-embedding-3-small: 1536# For text-embedding-3-large: 3072EMBEDDING_DIMENSIONS=1536

# ============================================================================
# PostgreSQL + pgvector Configuration
# ============================================================================

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mem0db
POSTGRES_USER=mem0user
POSTGRES_PASSWORD=mem0pass
POSTGRES_COLLECTION_NAME=memories

# ============================================================================
# Neo4j Configuration (Graph Memory)
# ============================================================================

NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=mem0graph

# ============================================================================
# Redis Configuration (Rate Limiting)
# ============================================================================

REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=mem0redis

# ============================================================================
# History Database
# ============================================================================

HISTORY_DB_PATH=/app/history/history.db

# ============================================================================
# Authentication
# ============================================================================

# Secret key for admin operations (CHANGE ME IN PRODUCTION!)
ADMIN_SECRET_KEY=change_me_in_production

# ============================================================================
# Rate Limiting
# ============================================================================

# Maximum requests per time window
RATE_LIMIT_REQUESTS=200

# Time window in seconds
RATE_LIMIT_WINDOW=60
